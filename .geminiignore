# Gemini CLI Ignore Patterns
# Supplementing .gitignore for better token/context optimization

# Ignore massive build and dependency directories
/target/
/vcpkg/
/vcpkg_installed/
/.git/
/tmp/
/.temp-archive/
/logs/
/.jules/
/.gemini/

# Assets and resources (usually too big for context)
/assets/
/resources/

# Binary Assets
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.mp4
*.mov
*.ogg
*.otf
*.ttf
*.woff
*.woff2
*.ico
*.pdf
*.psd
*.ai
*.zip
*.mmp

# Project Metadata/Secondary Config
.gitattributes
.markdownlint.json
.secrets.baseline
.pre-commit-config.yaml
deny.toml
rust-toolchain.toml
vcpkg.json
vcpkg-configuration.json

# Build/test output files
check_*.txt
*.pdb
*.tmp
*.bak
*.rs.bk
